# Copy to .env and fill in. Never commit your real token.
DISCORD_TOKEN=your-bot-token-here

# Optional: prefix for the text command (default "!", so !bolsas)
COMMAND_PREFIX=!

# Optional: how often (minutes) to check for newly-posted bolsas for !alerts
ALERT_INTERVAL_MIN=15

# --- apply (candidatura automation) ---
# Only needed for the automated form-filling mode (`!apply run`). The plain
# `!apply <edital>` package-prep works without any of these.
# Your own Fénix Connect login, used to sign in to the admissions portal:
FENIX_USER=
FENIX_PASS=
# Optional overrides:
# APPLY_PROFILE=/path/to/profile.json     # default: profile.json next to bot.py
# APPLY_OUT_DIR=/path/to/applications      # where prepared packages are written
# APPLY_SELECTORS={"login_user":"#username"}  # JSON, override portal selectors if the form changes
